# Coder Configuration Template
# Copy this file to .env and update with your actual values

# Coder Configuration
CODER_ACCESS_URL=https://coder.internal.earles.io
CODER_PG_CONNECTION_URL=postgres://coder:${POSTGRES_PASSWORD}@coder-db:5432/coder?sslmode=disable
CODER_PROVISIONER_DAEMON_COUNT=3
CODER_TELEMETRY_ENABLE=false
CODER_UPDATE_CHECK=false
CODER_HTTP_ADDRESS=0.0.0.0:7080

# Database Configuration
POSTGRES_PASSWORD=your_secure_password_here

# Azure AI Foundry Configuration (recommended for enterprise/PHI)
# Note: TF_VAR_ prefix makes these available to Coder workspace templates
# Authentication via 'az login' in workspace (no API key needed)
TF_VAR_claude_code_use_foundry=1
TF_VAR_anthropic_foundry_base_url=https://your-resource.services.ai.azure.com/anthropic

# Model Configuration (optional - specify default models)
TF_VAR_anthropic_default_sonnet_model=claude-sonnet-4-5
TF_VAR_anthropic_default_haiku_model=claude-haiku-4-5
TF_VAR_anthropic_default_opus_model=claude-opus-4-5

# Direct Anthropic API (alternative to Foundry - comment out if using Foundry)
# TF_VAR_anthropic_api_key=sk-ant-...

# OIDC / EntraID SSO (optional - uncomment and fill in when ready)
# CODER_OIDC_ISSUER_URL=https://login.microsoftonline.com/<tenant>/v2.0
# CODER_OIDC_CLIENT_ID=<client-id>
# CODER_OIDC_CLIENT_SECRET=<client-secret>
# CODER_OIDC_EMAIL_DOMAIN=yourdomain.com

# Docker Socket GID (auto-detected by run.sh)
DOCKER_GID=996
