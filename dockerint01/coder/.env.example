# Copy this to .env on the Docker LXC host and fill in values.
# Never commit .env — it is gitignored.

# Coder access URL — the LAN IP or hostname of your Docker LXC host
# run.sh will auto-detect this if left blank, or set it explicitly:
CODER_ACCESS_URL=http://192.168.x.x:7080

# Postgres password — generated by run.sh if left as-is
POSTGRES_PASSWORD=changeme

# Choose ONE of the following API options:

# Option A — Azure AI Foundry endpoint (recommended for enterprise/PHI)
# ANTHROPIC_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/claude/

# Option B — Direct Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...
